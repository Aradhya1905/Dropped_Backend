{
  "name": "dropped-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend for Dropped — anonymous, location-gated secret confessions (drop → walk → reveal).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/swagger": "^9.7.0",
    "@scalar/fastify-api-reference": "^1.59.3",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.1",
    "fastify-type-provider-zod": "^4.0.2",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
