# Dropped backend — environment.
# Copy to .env and fill in. The ONLY thing you must change to switch DB host is DATABASE_URL.

# Postgres connection (standard TCP, PostGIS-capable). Neon for now; any Postgres works.
# Neon requires sslmode=require. Self-hosted: drop it or set per your server.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# HTTP server
PORT=3000
HOST=0.0.0.0

# Anonymous-abuse throttles
DROP_DAILY_LIMIT=5

# Nearby query radii (meters)
NEARBY_DEFAULT_RADIUS_M=500
NEARBY_MAX_RADIUS_M=2000

# Moderation: number of reports that flips a drop to `pending` (shadow-removed)
REPORT_HIDE_THRESHOLD=3

# Walking-route proxy (GET /route/foot). Both optional — with neither key set the
# endpoint returns { available: false } and the client draws no path. ORS is tried
# first, Mapbox is the fallback. Get free keys at openrouteservice.org / mapbox.com.
ORS_API_KEY=
MAPBOX_TOKEN=
# Safety caps on monthly upstream calls per provider (under each free tier).
ORS_MONTHLY_LIMIT=60000
MAPBOX_MONTHLY_LIMIT=90000
# Route cache freshness (days).
ROUTE_CACHE_TTL_DAYS=21
